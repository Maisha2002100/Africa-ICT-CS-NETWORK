// ── SHOW COURSE ──────────────────────────────────────────────────────────
function showCourse() {
  document.getElementById('gateScreen').style.display = 'none'
  document.getElementById('mainLayout').style.display = 'grid'
  
  const courseId = getCourseId()
  curCourse = COURSE_CONTENT[courseId]
  
  // If we don't have static content, show a generic placeholder
  if (!curCourse) {
