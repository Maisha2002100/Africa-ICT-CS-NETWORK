        ]
      }]
    }
  }

  // Update nav user display
  if (currentUser) {
    const initials = (currentUser.email || 'U').substring(0,2).toUpperCase()
    document.getElementById('navUser').innerHTML = `
      <div class="nav-avatar">${initials}</div>
      <span>${currentUser.email?.split('@')[0] || 'Learner'}</span>`
  }

  // Update sidebar metadata
  document.getElementById('sideCat').textContent = curCourse.cat || 'Course'
  document.getElementById('sideTitle').textContent = curCourse.title
  document.getElementById('sideInstructor').innerHTML =
    `<b style="color:var(--white)">${curCourse.instructor}</b> &nbsp;·&nbsp; ${curCourse.school}`
  document.title = curCourse.title + ' — Africa ICT'

  // Flatten lessons into allLessons array
  allLessons = []
  curCourse.modules.forEach((mod, mi) => {
    mod.lessons.forEach((les, li) => {
      allLessons.push({ ...les, moduleTitle: mod.title, modIdx: mi, lesIdx: li, globalIdx: allLessons.length })
    })
  })

  // Load saved progress from localStorage
  const savedKey = 'progress_' + getCourseId()
  try {
    const saved = JSON.parse(localStorage.getItem(savedKey) || '[]')
    completedLessons = new Set(saved)
  } catch(e) { completedLessons = new Set() }

  buildSidebar()
  updateProgress()

  // Auto-open first incomplete lesson
  const firstIncomplete = allLessons.findIndex(l => !completedLessons.has(l.globalIdx))
  openLesson(firstIncomplete >= 0 ? firstIncomplete : 0)
}

// ── BUILD SIDEBAR ─────────────────────────────────────────────────────────
function buildSidebar() {
  const list = document.getElementById('moduleList')
  list.innerHTML = ''
  curCourse.modules.forEach((mod, mi) => {
    const header = document.createElement('div')
    header.className = 'module-header'
    header.textContent = mod.title
    list.appendChild(header)
    mod.lessons.forEach((les, li) => {
      const globalIdx = curCourse.modules.slice(0, mi).reduce((a,m) => a + m.lessons.length, 0) + li
      const item = document.createElement('div')
      item.className = 'lesson-item' + (completedLessons.has(globalIdx) ? ' done' : '')
      item.id = 'lesson-item-' + globalIdx
      item.onclick = () => openLesson(globalIdx)
      item.innerHTML = `
        <div class="l-check">✓</div>
        <div class="l-title">${les.title}</div>
        <div class="l-dur">${les.duration}</div>`
      list.appendChild(item)
    })
  })
}

