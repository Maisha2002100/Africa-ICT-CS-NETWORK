let completedLessons = new Set(), activeLessonIdx = -1, allLessons = []

// ── COURSE CONTENT ─────────────────────────────────────────────────────────
const COURSE_CONTENT = {"free-html-css": {"title": "HTML & CSS for Absolute Beginners", "instructor": "Amara Diallo", "school": "Dakar Institute of Tech", "hours": 8, "lessons": 40, "lang": "EN/SW", "cat": "Web Dev", "modules": [{"title": "Module 1: Introduction to HTML", "lessons": [{"title": "What is HTML?", "duration": "12 min", "youtube": "https://www.youtube.com/watch?v=UB1O30fR-EE", "reading": "HTML (HyperText Markup Language) is the standard language for creating web pages. HTML uses elements represented by tags like &lt;h1&gt;, &lt;p&gt;, &lt;div&gt;. A basic document has: &lt;!DOCTYPE html&gt;, &lt;html&gt;, &lt;head&gt; (metadata), and &lt;body&gt; (visible content). Tags are usually paired: opening &lt;p&gt; and closing &lt;/p&gt;. Some are self-closing like &lt;img/&gt; and &lt;br/&gt;."}, {"title": "HTML Document Structure", "duration": "15 min", "youtube": "https://www.youtube.com/watch?v=MDLn5-zSQQI", "reading": "Every HTML document follows a standard structure. The &lt;!DOCTYPE html&gt; declaration tells the browser this is HTML5. Inside &lt;head&gt; you place &lt;title&gt;, &lt;meta&gt; tags for character set and viewport, and CSS links. Semantic tags like &lt;header&gt;, &lt;main&gt;, &lt;footer&gt;, &lt;article&gt; and &lt;nav&gt; improve accessibility and SEO — always prefer them over generic &lt;div&gt; when the meaning fits."}, {"title": "Headings, Paragraphs & Text", "duration": "10 min", "youtube": "https://www.youtube.com/watch?v=WGzMzMbqnPw", "reading": "HTML has six heading levels h1 through h6. Use only one h1 per page — it is the main title. Paragraphs use &lt;p&gt;. Inline formatting: &lt;strong&gt; for bold importance, &lt;em&gt; for italic emphasis, &lt;mark&gt; for highlighting, &lt;code&gt; for inline code. Line breaks use &lt;br&gt;. Always write meaningful text — screen readers and search engines rely on it."}, {"title": "Links & Images", "duration": "14 min", "youtube": "https://www.youtube.com/watch?v=TSEBpMDr0RU", "reading": "Links use &lt;a href=\"url\"&gt;text&lt;/a&gt;. Use target=\"_blank\" to open in a new tab — always add rel=\"noopener noreferrer\" for security. Images use &lt;img src=\"path\" alt=\"description\"&gt;. The alt attribute is required for accessibility. Use width/height attributes to prevent layout shift while images load."}]}, {"title": "Module 2: CSS Fundamentals", "lessons": [{"title": "What is CSS & How It Works", "duration": "13 min", "youtube": "https://www.youtube.com/watch?v=1PnVor36_40", "reading": "CSS (Cascading Style Sheets) controls how HTML elements look. CSS rules have a selector and a declaration block: selector { property: value; }. CSS can be inline (style attribute), internal (style tag in head), or external (a .css file linked with link rel=\"stylesheet\"). External stylesheets are best practice. The \"cascading\" means later rules override earlier ones when specificity is equal."}, {"title": "Selectors & Specificity", "duration": "18 min", "youtube": "https://www.youtube.com/watch?v=l1mER1bV0N0", "reading": "Selectors target HTML elements: element (p), class (.card), ID (#header), attribute ([type=\"text\"]), pseudo-class (:hover, :focus, :nth-child). Specificity score: IDs (100) > Classes (10) > Elements (1). Use !important sparingly. Combinators: descendant (space), child (>), adjacent sibling (+), general sibling (~)."}, {"title": "Box Model & Layout", "duration": "20 min", "youtube": "https://www.youtube.com/watch?v=rIO5326FgPE", "reading": "Every HTML element is a box: content → padding → border → margin. Add box-sizing: border-box globally so width includes padding and border. Margin collapses vertically between adjacent block elements. display: block, inline, inline-block, or none controls rendering. Master the box model before learning Flexbox or Grid."}, {"title": "Flexbox for Modern Layouts", "duration": "22 min", "youtube": "https://www.youtube.com/watch?v=fYq5PXgSsbE", "reading": "Flexbox makes 1D layouts simple. Set display: flex on a 