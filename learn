  return p.get('id') || 'free-html-css'
}

// ── SHOW GATE ─────────────────────────────────────────────────────────────
function showGate() {
  document.getElementById('gateScreen').style.display = 'flex'
  document.getElementById('mainLayout').style.display = 'none'
}
function gateSignup() {
  const returnUrl = encodeURIComponent(location.href)
  window.location.href = 'index.html?action=signup&returnUrl=' + returnUrl
}
function gateSignin() {
  const returnUrl = encodeURIComponent(location.href)
