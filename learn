<style>
:root{
  --navy:#0e1c2e;--navy2:#112035;--navy3:#162840;
  --cyan:#00c8d4;--cyan2:#009eb0;
  --gold:#f5a800;--amber:#e07800;
  --white:#f0f6ff;--body:#8aa8c8;--muted:#4e6e8e;
  --border:rgba(0,200,212,0.13);--border2:rgba(0,200,212,0.26);
  --card:#112035;--surface:rgba(255,255,255,0.04);
  --green:#22c55e;--red:#ef4444;
  --radius:14px;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:"Plus Jakarta Sans",sans-serif;background:var(--navy);color:var(--white);min-height:100vh;line-height:1.6}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:var(--navy2)}::-webkit-scrollbar-thumb{background:var(--cyan2);border-radius:4px}

/* NAV */
.nav{position:sticky;top:0;z-index:200;background:rgba(14,28,46,.97);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);padding:0 5%;height:64px;display:flex;align-items:center;gap:14px}
.nav-logo{display:flex;align-items:center;gap:10px;text-decoration:none;flex-shrink:0}
.nav-logo img{width:38px;height:38px;border-radius:9px;object-fit:cover}
.nav-logo-name{font-size:13px;font-weight:800;color:var(--white)}
.nav-logo-sub{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.07em}
.nav-back{margin-left:auto;display:flex;align-items:center;gap:8px;background:var(--surface);border:1.5px solid var(--border);border-radius:10px;padding:8px 14px;color:var(--body);font-size:13px;font-weight:600;cursor:pointer;text-decoration:none;transition:all .2s}
.nav-back:hover{border-color:var(--cyan);color:var(--white)}
.nav-user{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--body)}
.nav-avatar{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--cyan),var(--gold));display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;color:#0e1c2e;flex-shrink:0}

/* GATE — shown when not logged in */
#gateScreen{display:none;position:fixed;inset:0;z-index:500;background:rgba(0,0,0,.96);backdrop-filter:blur(20px);align-items:center;justify-content:center;padding:20px}
.gate-box{background:var(--navy2);border:1.5px solid var(--border2);border-radius:24px;width:100%;max-width:440px;padding:40px 36px;text-align:center}
.gate-logo{width:80px;height:80px;border-radius:18px;object-fit:cover;margin:0 auto 20px;display:block;box-shadow:0 0 0 4px rgba(0,200,212,.2)}
.gate-title{font-family:"Fraunces",serif;font-size:24px;font-weight:900;margin-bottom:8px}
.gate-sub{font-size:14px;color:var(--body);margin-bottom:28px;line-height:1.6}
.gate-btn{width:100%;padding:14px;border:none;border-radius:12px;font-weight:800;font-size:15px;cursor:pointer;font-family:inherit;margin-bottom:10px;transition:opacity .2s}
.gate-btn:hover{opacity:.9}
.gate-primary{background:linear-gradient(135deg,var(--cyan),var(--gold));color:#0e1c2e}
.gate-secondary{background:var(--surface);border:1.5px solid var(--border2);color:var(--white)}

/* LAYOUT */
.layout{display:grid;grid-template-columns:320px 1fr;min-height:calc(100vh - 64px)}
@media(max-width:900px){.layout{grid-template-columns:1fr}}

/* SIDEBAR */
.sidebar{background:var(--navy2);border-right:1px solid var(--border);overflow-y:auto;max-height:calc(100vh - 64px);position:sticky;top:64px}
.course-meta{padding:24px 20px 20px;border-bottom:1px solid var(--border)}
.course-cat-badge{display:inline-block;padding:4px 10px;background:rgba(0,200,212,.1);border:1px solid rgba(0,200,212,.3);border-radius:20px;font-size:11px;color:var(--cyan);font-weight:700;letter-spacing:.06em;text-transform:uppercase;margin-bottom:10px}
.course-title{font-family:"Fraunces",serif;font-size:17px;font-weight:900;line-height:1.3;color:var(--white);margin-bottom:8px}
.course-instructor{font-size:12px;color:var(--muted)}
.progress-bar-wrap{padding:16px 20px;border-bottom:1px solid var(--border)}
.progress-label{display:flex;justify-content:space-between;font-size:12px;color:var(--muted);margin-bottom:8px}
.progress-track{height:6px;background:var(--surface);border-radius:3px;overflow:hidden}
.progress-fill{height:100%;background:linear-gradient(90deg,var(--cyan),var(--gold));border-radius:3px;transition:width .4s ease}
.module-wrap{padding:12px 0}
.module-header{padding:10px 20px;font-size:12px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em}
.lesson-item{display:flex;align-items:center;gap:12px;padding:10px 20px;cursor:pointer;transition:background .15s;border-left:3px solid transparent}
.lesson-item:hover{background:rgba(0,200,212,.05)}
.lesson-item.active{background:rgba(0,200,212,.08);border-left-color:var(--cyan)}
.lesson-item.done .l-check{background:var(--green);border-color:var(--green);color:#fff}
.l-check{width:22px;height:22px;border-radius:50%;border:2px solid var(--border2);display:flex;align-items:center;justify-content:center;font-size:10px;flex-shrink:0;transition:all .2s;color:transparent}
.l-title{font-size:13px;color:var(--body);flex:1;line-height:1.3}
.lesson-item.active .l-title{color:var(--white);font-weight:600}
.l-dur{font-size:11px;color:var(--muted);flex-shrink:0}
.sidebar-complete{padding:16px 20px;border-top:1px solid var(--border)}
.cert-btn{width:100%;padding:12px;background:linear-gradient(135deg,var(--gold),var(--amber));border:none;border-radius:10px;color:#0e1c2e;font-weight:800;font-size:13px;cursor:pointer;font-family:inherit;transition:opacity .2s}
.cert-btn:hover{opacity:.9}

/* MAIN CONTENT AREA */
.main{overflow-y:auto;max-height:calc(100vh - 64px)}
.lesson-view{padding:36px 40px}
@media(max-width:700px){.lesson-view{padding:20px 16px}}

/* VIDEO SECTION */
.video-section{background:var(--navy2);border:1.5px solid var(--border);border-radius:18px;overflow:hidden;margin-bottom:28px}
.video-label{padding:12px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;font-size:12px;color:var(--muted);font-weight:600}
.video-icon{width:20px;height:20px;background:#ff0000;border-radius:4px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.video-icon svg{width:10px;height:10px;fill:white}
.video-placeholder{aspect-ratio:16/9;background:linear-gradient(135deg,#0e1c2e 0%,#162840 100%);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;cursor:pointer;transition:background .2s;text-decoration:none}
.video-placeholder:hover{background:linear-gradient(135deg,#112035 0%,#1a3050 100%)}
.play-btn{width:72px;height:72px;border-radius:50%;background:rgba(255,0,0,.85);display:flex;align-items:center;justify-content:center;transition:transform .2s,background .2s;box-shadow:0 8px 32px rgba(255,0,0,.3)}
.video-placeholder:hover .play-btn{transform:scale(1.08);background:rgba(255,0,0,1)}
.play-btn svg{width:28px;height:28px;fill:white;margin-left:4px}
.video-title-text{font-size:15px;font-weight:700;color:var(--white);text-align:center;padding:0 20px}
.video-yt-link{font-size:12px;color:var(--cyan);margin-top:4px}

/* LESSON HEADER */
.lesson-header{margin-bottom:24px}
.lesson-num{font-size:12px;color:var(--cyan);font-weight:700;letter-spacing:.06em;text-transform:uppercase;margin-bottom:6px}
.lesson-title-main{font-family:"Fraunces",serif;font-size:26px;font-weight:900;line-height:1.2;margin-bottom:12px}
.lesson-meta-row{display:flex;align-items:center;gap:16px;flex-wrap:wrap}
.lesson-tag{display:inline-flex;align-items:center;gap:5px;padding:5px 10px;background:var(--surface);border:1px solid var(--border);border-radius:20px;font-size:12px;color:var(--body)}

/* READING SECTION */
.reading-section{background:var(--navy2);border:1.5px solid var(--border);border-radius:18px;padding:28px;margin-bottom:24px}
.reading-header{display:flex;align-items:center;gap:10px;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid var(--border)}
.reading-icon{width:36px;height:36px;border-radius:10px;background:rgba(0,200,212,.1);border:1px solid rgba(0,200,212,.2);display:flex;align-items:center;justify-content:center}
.reading-icon svg{width:18px;height:18px;stroke:var(--cyan);fill:none}
.reading-title{font-size:15px;font-weight:700;color:var(--white)}
.reading-sub{font-size:12px;color:var(--muted)}
.reading-body{font-size:14.5px;color:var(--body);line-height:1.85}
.reading-body code{background:rgba(0,200,212,.08);border:1px solid rgba(0,200,212,.15);border-radius:5px;padding:2px 6px;font-size:13px;color:var(--cyan);font-family:monospace}

/* NAV BUTTONS */
.lesson-nav{display:flex;gap:12px;margin-top:28px;padding-top:24px;border-top:1px solid var(--border)}
.ln-btn{flex:1;padding:14px;border-radius:12px;font-weight:700;font-size:14px;cursor:pointer;font-family:inherit;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:8px}
.ln-prev{background:var(--surface);border:1.5px solid var(--border2);color:var(--white)}
.ln-prev:hover{border-color:var(--cyan);color:var(--cyan)}
.ln-next{background:linear-gradient(135deg,var(--cyan),var(--gold));border:none;color:#0e1c2e}
.ln-next:hover{opacity:.9}
.ln-btn:disabled{opacity:.35;cursor:not-allowed}

/* COMPLETION TOAST */
.toast{position:fixed;bottom:24px;right:24px;background:var(--navy2);border:1.5px solid var(--green);border-radius:14px;padding:14px 18px;display:flex;align-items:center;gap:10px;z-index:999;transform:translateY(80px);opacity:0;transition:all .3s}
.toast.show{transform:translateY(0);opacity:1}
.toast-icon{width:28px;height:28px;border-radius:50%;background:var(--green);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.toast-icon svg{width:14px;height:14px;stroke:white;fill:none}
.toast-msg{font-size:13px;font-weight:600;color:var(--white)}

/* EMPTY STATE */
.empty-state{padding:80px 40px;text-align:center}
.empty-state h2{font-family:"Fraunces",serif;font-size:22px;margin-bottom:10px}
.empty-state p{color:var(--muted);font-size:14px}

@media(max-width:900px){
  .sidebar{position:static;max-height:none;border-right:none;border-bottom:1px solid var(--border)}
  .main{max-height:none}
}
</style>
</head>
