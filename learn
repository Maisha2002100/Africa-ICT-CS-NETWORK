// ── MARK LESSON DONE ──────────────────────────────────────────────────────
function markDone(globalIdx) {
  completedLessons.add(globalIdx)
  // Save to localStorage
  try {
    localStorage.setItem('progress_' + getCourseId(), JSON.stringify([...completedLessons]))
  } catch(e) {}
  // Update sidebar
  const item = document.getElementById('lesson-item-' + globalIdx)
  if (item) item.classList.add('done')
  updateProgress()
  showToast('Lesson complete! Keep going 🚀')
  // Auto advance to next lesson
  setTimeout(() => {
    if (globalIdx + 1 < allLessons.length) openLesson(globalIdx + 1)
    else openLesson(globalIdx) // refresh to show "completed" state
  }, 800)
}

// ── UPDATE PROGRESS BAR ───────────────────────────────────────────────────
function updateProgress() {
  const total = allLessons.length
  const done = completedLessons.size
  const pct = total > 0 ? Math.round((done / total) * 100) : 0
  document.getElementById('progressPct').textContent = pct + '%'
  document.getElementById('progressFill').style.width = pct + '%'
  const certBtn = document.getElementById('certBtn')
  if (certBtn) certBtn.style.display = pct === 100 ? 'block' : 'none'
}

// ── HELPERS ───────────────────────────────────────────────────────────────
function extractYTId(url) {
  if (!url) return null
  const m = url.match(/(?:v=|youtu\.be\/)([\w-]{11})/)
  return m ? m[1] : null
}

function formatReading(text) {
  if (!text) return '<p style="color:var(--muted)">Reading material coming soon.</p>'
  // Bold **text**
  text = text.replace(/\*\*(.+?)\*\*/g, '<strong style="color:var(--white)">$1</strong>')
  // Code `text`
  text = text.replace(/`([^`]+)`/g, '<code>$1</code>')
  // Split into paragraphs on double newline or sentences > 120 chars
  const sentences = text.split(/(?<=\.) (?=[A-Z])/)
  const chunks = []
  let current = ''
  sentences.forEach(s => {
    current += (current ? ' ' : '') + s
    if (current.length > 300) { chunks.push(current); current = '' }
  })
  if (current) chunks.push(current)
  return chunks.map(c => `<p style="margin-bottom:16px">${c}</p>`).join('')
}

function showToast(msg) {
  const t = document.getElementById('toast')
  document.getElementById('toastMsg').textContent = msg
  t.classList.add('show')
  setTimeout(() => t.classList.remove('show'), 3000)
}

