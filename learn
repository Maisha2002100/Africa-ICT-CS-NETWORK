        lessons: [
          { title: 'Welcome to the Course', duration: '5 min', youtube: 'https://www.youtube.com/results?search_query=' + encodeURIComponent(new URLSearchParams(location.search).get('title') || 'programming tutorial'), reading: 'Welcome! This course content is being prepared by your instructor. Please check back soon for full reading materials and video lessons. In the meantime, use the YouTube link above to find related learning resources.' },
